# Supabase Configuration
# These environment variables are required for the application to connect to Supabase
# and enable features like authentication, data storage, and real-time updates.

# Supabase Project URL
# This is your Supabase project's public URL
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co

# Supabase Anon Key
# This is your Supabase project's anonymous (public) key for client-side operations
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Application URL
# This is used for password reset links and other redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database URL for Server-Side Operations
# This is your Supabase PostgreSQL database connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?sslmode=require
DATABASE_URL=postgresql://postgres:your-password@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# Demo Mode
# Set to 'true' to use mock data for development without Supabase
# Set to 'false' to use your real Supabase backend
NEXT_PUBLIC_DEMO_MODE=false
