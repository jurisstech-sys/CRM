// Jurisla CRM — Prisma schema
// OBS: O runtime do app utiliza o cliente Supabase diretamente (lib/supabase.ts).
// Este schema documenta o modelo de dados e pode ser usado por `prisma generate`/`prisma db pull`.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid()) @db.Uuid
  email                  String    @unique
  fullName               String?   @map("full_name")
  phone                  String?
  role                   String    @default("comercial") // admin | super_admin | comercial | user | viewer
  department             String?
  status                 String    @default("active")
  lastLogin              DateTime? @map("last_login") @db.Timestamptz
  commissionRate         Decimal   @default(0) @map("commission_rate") @db.Decimal(5, 2)
  monthlyCommissionTotal Decimal   @default(0) @map("monthly_commission_total") @db.Decimal(15, 2)
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  leads             Lead[]             @relation("AssignedLeads")
  commissions       Commission[]
  commissionConfigs CommissionConfig[]

  @@map("users")
}

model Plan {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  price       Decimal? @db.Decimal(15, 2) // NULL = valor personalizado (Enterprise)
  isCustom    Boolean  @default(false) @map("is_custom")
  currency    String   @default("BRL")
  active      Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz

  leads Lead[]

  @@map("plans")
}

model Lead {
  id                 String    @id @default(uuid()) @db.Uuid
  clientId           String?   @map("client_id") @db.Uuid
  title              String
  description        String?
  source             String?
  value              Decimal?  @db.Decimal(15, 2)
  customValue        Decimal?  @map("custom_value") @db.Decimal(15, 2)
  planId             String?   @map("plan_id") @db.Uuid
  currency           String    @default("BRL")
  status             String    @default("backlog")
  assignedTo         String?   @map("assigned_to") @db.Uuid
  expectedCloseDate  DateTime? @map("expected_close_date") @db.Date
  probability        Decimal?  @default(0) @db.Decimal(5, 2)
  email1             String?
  email2             String?
  email3             String?
  phone1             String?
  phone2             String?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  plan         Plan?        @relation(fields: [planId], references: [id])
  assignedUser User?        @relation("AssignedLeads", fields: [assignedTo], references: [id])
  commissions  Commission[]

  @@map("leads")
}

model CommissionConfig {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  stage      String
  percentage Decimal  @default(0) @db.Decimal(5, 2)
  createdBy  String?  @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, stage])
  @@map("commission_config")
}

model Commission {
  id                String    @id @default(uuid()) @db.Uuid
  leadId            String    @map("lead_id") @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  amount            Decimal   @db.Decimal(15, 2)
  percentage        Decimal?  @db.Decimal(5, 2)
  currency          String    @default("BRL")
  status            String    @default("pending") // pending | approved | paid | cancelled
  calculationMethod String?   @map("calculation_method")
  paymentDate       DateTime? @map("payment_date") @db.Date
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  lead Lead @relation(fields: [leadId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@map("commissions")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  actionType  String   @map("action_type") // create | update | delete | move
  entityType  String   @map("entity_type") // client | lead | commission | file
  entityId    String   @map("entity_id")
  entityName  String?  @map("entity_name")
  description String
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([entityType, entityId])
  @@map("activity_logs")
}
