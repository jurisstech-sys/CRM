# .env.local - Local Development Configuration
# ================================================
# 
# This file contains environment variables for local development.
# Copy this file to .env.local and fill in your actual Supabase credentials.
# 
# IMPORTANT: Never commit the actual .env.local file to Git!
# The .env.local file is in .gitignore to prevent exposing sensitive credentials.

# Step 1: Get your Supabase credentials
# ======================================
# 1. Go to https://supabase.com and create a new project
# 2. Once the project is created, navigate to Settings > API
# 3. Copy the values for:
#    - Project URL (for NEXT_PUBLIC_SUPABASE_URL)
#    - Anon Key (for NEXT_PUBLIC_SUPABASE_ANON_KEY)
#    - Database Password (for DATABASE_URL password)

# Step 2: Update the values below
# ================================

# Your Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here

# Your Supabase anonymous (public) key
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Your application URL (for redirects and links)
# For local development, this is typically:
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Your Supabase PostgreSQL connection string
# Format: postgresql://postgres:[YOUR_DATABASE_PASSWORD]@[YOUR_SUPABASE_HOST]:6543/postgres
# Replace:
#   [YOUR_DATABASE_PASSWORD] - Your Supabase database password
#   [YOUR_SUPABASE_HOST] - Your Supabase host (e.g., aws-1-us-east-2.pooler.supabase.com)
# Example: postgresql://postgres:your-password@aws-1-us-east-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:your-database-password@your-supabase-host:6543/postgres

# Demo Mode
# Set to 'true' to use mock data for development
# Set to 'false' to use your real Supabase backend
NEXT_PUBLIC_DEMO_MODE=false

# Step 3: Verify your configuration
# ==================================
# 1. Start the development server: npm run dev
# 2. Navigate to http://localhost:3000
# 3. Try to register a new account
# 4. Check if the user is created in your Supabase project
# 5. Try to log in with the created credentials

# Step 4: Create tables in Supabase (if not already done)
# ========================================================
# Run the SQL scripts provided in the SETUP.md file to create:
# - users table
# - leads table
# - lead_phones table
# - lead_emails table
# - lead_pipeline_states table
# - lead_interactions table
# - commissions table
# - commission_periods table

# For more information, see:
# - SETUP.md - Project setup and configuration guide
# - FASE2.md - Phase 2 features documentation
# - FASE3.md - Phase 3 features documentation
